# =============================================================================
# Liaqat Rice Mill — Environment Template
# Copy to .env and adjust values:  cp .env.example .env
# =============================================================================

# --- Frontend (Vite / React) ---
VITE_PORT=3000
VITE_HOST=0.0.0.0
# Leave empty to use Vite proxy (/api → backend)
VITE_API_URL=

# --- Backend (Django) ---
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8006

# --- Public URLs ---
# Production: set to your server IP or domain (include port if not 80)
APP_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Deploy (production only) ---
# PUBLIC_PORT=8010
# APP_URL=https://yourdomain.com
# CORS_ORIGINS=https://yourdomain.com

# --- Django settings ---
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Admin panel (demo login) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# --- AI / External APIs ---
GEMINI_API_KEY=

# --- Dev tools ---
DISABLE_HMR=false
